# Email capture — optional Formspree URL (safe as NEXT_PUBLIC_*; posts from the browser).

# Formspree: create a form at https://formspree.io and paste the POST URL (e.g. https://formspree.io/f/abcxyz)
NEXT_PUBLIC_FORMSPREE_FORM_ENDPOINT=

# Without NEXT_PUBLIC_FORMSPREE_FORM_ENDPOINT, submit still succeeds in demo mode (no forwarding).
